rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Moderator check: document ID in the users collection MUST equal the Auth UID.
    // To add a moderator: Firebase console → Firestore → users → Add document,
    // set the Document ID to the user's Auth UID (not auto-ID).
    function isModerator() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    match /posts/{postId} {
      // Anyone can read active or archived posts
      allow read: if resource.data.status != 'deleted';

      // Anyone can create a post (anonymous submission)
      allow create: if request.resource.data.keys().hasAll(['content', 'nickname', 'createdAt', 'upvotes', 'upvotedBy', 'status'])
        && request.resource.data.content is string
        && request.resource.data.content.size() <= 1000
        && request.resource.data.nickname is string
        && request.resource.data.upvotes == 0
        && request.resource.data.upvotedBy == []
        && request.resource.data.status == 'active';

      // Anyone (including unauthenticated) can upvote or un-upvote.
      // No auth check here — field constraints are the only gate needed:
      // only upvotes and upvotedBy may change, and the count must move by exactly ±1.
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['upvotes', 'upvotedBy'])
        && (request.resource.data.upvotes == resource.data.upvotes + 1
            || request.resource.data.upvotes == resource.data.upvotes - 1);

      // Moderator can delete (set status = deleted) or archive (set status = archived)
      allow update: if isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'deletedAt'])
        && request.resource.data.status == 'deleted';

      allow update: if isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'archivedAt'])
        && request.resource.data.status == 'archived';

      // Moderator can select a post for the current session
      allow update: if isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status', 'selectedAt'])
        && request.resource.data.status == 'selected';

      // Moderator can unselect a post (revert selected → active)
      allow update: if isModerator()
        && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['status'])
        && request.resource.data.status == 'active'
        && resource.data.status == 'selected';

      // No hard deletes
      allow delete: if false;
    }

    // users collection: moderator UID registry
    match /users/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false; // managed via Firebase console only
    }

    // config collection: public read, moderator write
    match /config/{docId} {
      allow read: if true;
      allow write: if isModerator();
    }
  }
}
